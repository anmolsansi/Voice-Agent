{
  "name": "voice-agent",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "voice-agent",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "engines": {
        "node": ">=20"
      }
    },
    "apps/backend": {
      "name": "@voice-agent/backend",
      "version": "0.1.0"
    },
    "apps/frontend": {
      "name": "@voice-agent/frontend",
      "version": "0.1.0"
    },
    "node_modules/@voice-agent/backend": {
      "resolved": "apps/backend",
      "link": true
    },
    "node_modules/@voice-agent/frontend": {
      "resolved": "apps/frontend",
      "link": true
    },
    "node_modules/@voice-agent/shared-types": {
      "resolved": "packages/shared-types",
      "link": true
    },
    "packages/shared-types": {
      "name": "@voice-agent/shared-types",
      "version": "0.1.0"
    }
  }
}
